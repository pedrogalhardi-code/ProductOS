// ProductOS — Prisma Schema
// SQLite for local dev — enums not supported, using String fields with valid values in comments
// For production: change provider to "postgresql" and restore enum types

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   @default("EDITOR") // ADMIN | EDITOR | VIEWER
  avatarUrl    String?  // data URL or remote URL for the profile picture
  passwordHash String?  // bcrypt hash; nullable for legacy users, set on register/change
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  authoredDocuments Document[]      @relation("DocumentAuthor")
  versions          DocVersion[]
  comments          Comment[]
  auditLogs         AuditLog[]
  projectMembers    ProjectMember[]
  integrations      Integration[]
  settings          UserSettings?

  @@map("users")
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  language           String   @default("en")
  tone               String   @default("Formal") // Formal | Startup | Technical
  systemPromptPrefix String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Project {
  id            String   @id @default(cuid())
  name          String
  description   String?
  clientContext String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  documents   Document[]
  members     ProjectMember[]
  attachments ProjectAttachment[]

  @@map("projects")
}

model ProjectAttachment {
  id        String   @id @default(cuid())
  projectId String
  name      String
  size      Int
  text      String   // extracted text from PDF/document, used as additional context
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_attachments")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("VIEWER") // ADMIN | EDITOR | VIEWER
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Document {
  id                String   @id @default(cuid())
  title             String
  type              String   // PRD | USER_STORIES | TECHNICAL_SPEC | PRODUCT_BRIEF | ROADMAP | OKRS
  status            String   @default("DRAFT") // DRAFT | IN_REVIEW | APPROVED | ARCHIVED
  content           String   @default("")
  projectId         String
  authorId          String
  currentVersionId  String?
  jiraEpicKey       String?
  figmaFileUrl      String?
  figmaFileName     String?
  figmaLastModified String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author    User         @relation("DocumentAuthor", fields: [authorId], references: [id])
  versions  DocVersion[]
  comments  Comment[]
  auditLogs AuditLog[]

  @@map("documents")
}

model DocVersion {
  id         String   @id @default(cuid())
  documentId String
  content    String
  label      String?
  changes    String?  // human-readable change description, e.g. "Updated success metrics"
  createdAt  DateTime @default(now())
  authorId   String

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])

  @@map("doc_versions")
}

model Comment {
  id         String   @id @default(cuid())
  documentId String
  authorId   String
  anchorId   String
  body       String
  resolved   Boolean  @default(false)
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [authorId], references: [id])
  replies  Comment[] @relation("CommentReplies")
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])

  @@map("comments")
}

model Integration {
  id           String    @id @default(cuid())
  userId       String
  service      String    // JIRA | CONFLUENCE | SLACK | FIGMA | GOOGLE_DRIVE
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  metadata     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, service])
  @@map("integrations")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  documentId String?
  action     String   // CREATED | UPDATED | DELETED | EXPORTED | SHARED | STATUS_CHANGED | PUSHED_TO_JIRA | PUSHED_TO_CONFLUENCE | PUSHED_TO_GDRIVE | SLACK_NOTIFIED | REVIEWED | COMMENTED | VERSION_RESTORED
  metadata   String?
  timestamp  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
