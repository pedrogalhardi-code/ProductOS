# Database
DATABASE_URL="postgresql://productos:productos@localhost:5432/productos_dev"
# For local dev with SQLite: "file:./dev.db"

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Auth0 (or Clerk)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.productos.telus.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# AWS S3 / Cloudflare R2 (for exports)
S3_BUCKET=productos-exports
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret

# Jira
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret

# Confluence
CONFLUENCE_BASE_URL=https://yourorg.atlassian.net/wiki
CONFLUENCE_CLIENT_ID=your-confluence-client-id
CONFLUENCE_CLIENT_SECRET=your-confluence-client-secret

# Slack
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Google Drive
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/gdrive/callback

# Figma
FIGMA_CLIENT_ID=your-figma-client-id
FIGMA_CLIENT_SECRET=your-figma-client-secret

# Rate Limiting
RATE_LIMIT_AI_REQUESTS_PER_HOUR=20
RATE_LIMIT_WINDOW_MS=3600000
